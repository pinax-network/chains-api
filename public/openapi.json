    "/slip44/{coinType}": {
      "get": {
        "tags": [
          "SLIP-44"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "pattern": "^-?\\d+$",
              "errorMessage": "Invalid coin type"
            },
            "in": "path",
            "name": "coinType",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response"
