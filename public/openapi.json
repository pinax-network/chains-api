  "servers": [
    {
      "url": "https://chains-api.johnaverse.cc",
      "description": "Production"
    },
    {
      "url": "http://localhost:3000",
      "description": "Local"
    }
  ],
  "tags": [
    {
      "name": "Chains",
      "description": "Chain metadata, search, and lookup"
    },
    {
      "name": "Relations",
      "description": "L2 / testnet / parent relationships and graph traversal"
    },
    {
      "name": "Endpoints",
      "description": "RPC, firehose, and substreams endpoints per chain"
    },
    {
      "name": "RPC Monitor",
      "description": "Live RPC endpoint health results"
    },
    {
      "name": "Clients",
      "description": "Execution-client registry and versions"
    },
    {
      "name": "Scaling",
