{
  "openapi": "3.1.0",
  "info": {
    "title": "Chains API",
    "description": "Aggregated blockchain chain data from five external sources (TheGraph, Chainlist, Chain ID Network, SLIP-0044, L2BEAT): chain metadata, relations, RPC endpoints and health, L2 scaling, and operator status.",
    "version": "1.4.0"
  },
  "components": {
    "schemas": {}
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "Meta"
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/sources": {
      "get": {
        "tags": [
          "Meta"
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/export": {
      "get": {
        "tags": [
          "Meta"
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/reload": {
      "post": {
        "tags": [
          "Admin"
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/validate": {
      "get": {
        "tags": [
          "Validation"
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/keywords": {
      "get": {
        "tags": [
          "Keywords"
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/stats": {
      "get": {
        "tags": [
          "Stats"
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/chains": {
      "get": {
        "tags": [
          "Chains"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "enum": [
                "Testnet",
                "L2",
                "Beacon",
                "ZK",
                "Validium",
                "Optimium"
              ],
              "errorMessage": {
                "enum": "Invalid tag. Allowed: Testnet, L2, Beacon, ZK, Validium, Optimium"
              }
            },
            "in": "query",
            "name": "tag",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/chains/{id}": {
      "get": {
        "tags": [
          "Chains"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "pattern": "^-?\\d+$",
              "errorMessage": "Invalid chain ID"
            },
            "in": "path",
            "name": "id",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/search": {
      "get": {
        "tags": [
          "Chains"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200,
              "errorMessage": {
                "minLength": "Query parameter \"q\" is required",
                "maxLength": "Query too long. Max length: 200"
              }
            },
            "in": "query",
            "name": "q",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/relations": {
      "get": {
        "tags": [
          "Relations"
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/relations/{id}": {
      "get": {
        "tags": [
          "Relations"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "pattern": "^-?\\d+$",
              "errorMessage": "Invalid chain ID"
            },
            "in": "path",
            "name": "id",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/relations/{id}/graph": {
      "get": {
        "tags": [
          "Relations"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5,
              "default": 2,
              "errorMessage": "Invalid depth. Must be between 1 and 5"
            },
            "in": "query",
            "name": "depth",
            "required": false
          },
          {
            "schema": {
              "type": "string",
              "pattern": "^-?\\d+$",
              "errorMessage": "Invalid chain ID"
            },
            "in": "path",
            "name": "id",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/endpoints": {
      "get": {
        "tags": [
          "Endpoints"
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/endpoints/{id}": {
      "get": {
        "tags": [
          "Endpoints"
        ],
