    "/summary": {
      "get": {
        "tags": [
          "Meta"
        ],
        "description": "Slim projection of all chains (id, name, tags, relations, RPC count) plus L2BEAT headline data. Designed for dashboards; a fraction of the size of /export. Supports ETag revalidation (If-None-Match → 304).",
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/assistant": {
      "get": {
        "tags": [
          "Assistant"
        ],
        "description": "Assistant availability probe. Reports whether the chat assistant is configured, which model backs it, whether the LLM server is currently reachable (checked live, cached ~30s; null when disabled), and the per-request time budget actually in effect — useful to verify a config rollout landed.",
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean"
                    },
                    "model": {
                      "type": [
                        "null",
                        "string"
                      ]
                    },
                    "reachable": {
                      "type": [
                        "null",
                        "boolean"
                      ]
                    },
                    "timeoutMs": {
                      "type": [
                        "null",
                        "number"
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/assistant/chat": {
      "post": {
        "tags": [
          "Assistant"
        ],
        "description": "Chat with the assistant about chains, endpoints, scaling, relations, live incidents, and forum news. Stateless: send the full conversation each turn; the assistant may reply with a clarifying question (e.g. mainnet vs testnet) — answer it in a follow-up message. Fast answers return 200 directly; slow LLM runs return 202 with a job id to poll at GET /assistant/chat/:jobId (keeps every request under reverse-proxy timeouts).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "messages": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 20,
                    "items": {
                      "type": "object",
                      "properties": {
                        "role": {
                          "type": "string",
                          "enum": [
                            "user",
                            "assistant"
                          ],
                          "errorMessage": {
                            "enum": "Message role must be \"user\" or \"assistant\""
                          }
                        },
                        "content": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 4000,
                          "errorMessage": {
                            "minLength": "Message content must not be empty",
                            "maxLength": "Message content too long. Max length: 4000"
                          }
                        }
                      },
                      "required": [
                        "role",
                        "content"
                      ],
                      "additionalProperties": false
                    },
                    "errorMessage": {
                      "minItems": "At least one message is required",
                      "maxItems": "Too many messages. Max: 20"
                    }
                  },
                  "context": {
                    "type": "object",
                    "properties": {
                      "view": {
                        "type": "string",
                        "maxLength": 40
                      },
                      "chainId": {
                        "type": "number"
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": [
                  "messages"
                ],
                "additionalProperties": false,
                "errorMessage": {
                  "required": {
                    "messages": "Field \"messages\" is required"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "reply": {
                      "type": "string"
                    },
                    "toolCalls": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string"
                          },
                          "args": {
                            "type": "object",
                            "additionalProperties": true
                          }
                        }
                      }
                    },
                    "degraded": {
                      "type": "boolean"
                    },
                    "offTopic": {
                      "type": "boolean"
                    },
                    "usage": {
                      "type": [
                        "null",
                        "object"
                      ],
                      "properties": {
                        "promptTokens": {
                          "type": [
                            "null",
                            "number"
                          ]
                        },
                        "completionTokens": {
                          "type": [
                            "null",
                            "number"
                          ]
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "202": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "jobId": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    },
                    "pollAfterMs": {
                      "type": "number"
                    },
                    "budgetMs": {
                      "type": "number"
                    },
                    "steps": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "label": {
                            "type": "string"
                          },
                          "at": {
                            "type": "number"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/assistant/chat/{jobId}": {
      "get": {
        "tags": [
          "Assistant"
        ],
        "description": "Poll an async assistant job started by POST /assistant/chat (202 response). Returns status running/done/error; done responses carry the full chat result. Finished jobs expire after ~10 minutes.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "pattern": "^[A-Za-z0-9-]+$",
              "errorMessage": {
                "pattern": "Invalid job id"
              }
            },
            "in": "path",
            "name": "jobId",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "jobId": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    },
                    "pollAfterMs": {
                      "type": "number"
                    },
                    "steps": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "label": {
                            "type": "string"
                          },
                          "at": {
                            "type": "number"
                          }
                        }
                      }
                    },
                    "error": {
                      "type": "string"
                    },
                    "reply": {
                      "type": "string"
                    },
                    "toolCalls": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string"
                          },
                          "args": {
                            "type": "object",
                            "additionalProperties": true
                          }
                        }
                      }
                    },
                    "degraded": {
                      "type": "boolean"
                    },
                    "offTopic": {
                      "type": "boolean"
                    },
                    "usage": {
                      "type": [
                        "null",
                        "object"
                      ],
                      "properties": {
                        "promptTokens": {
                          "type": [
                            "null",
                            "number"
                          ]
                        },
                        "completionTokens": {
                          "type": [
                            "null",
                            "number"
                          ]
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/": {
      "get": {
        "tags": [
          "Meta"
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    }
  },
